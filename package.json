{
	"name": "@ruah-dev/orch",
	"version": "1.1.2",
	"description": "Thin installer for ruah orchestration. Installs the top-level CLI and orch core package.",
	"type": "module",
	"files": [
		"postinstall.mjs",
		"test/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"postinstall": "node postinstall.mjs",
		"test": "node --test test/*.test.mjs",
		"lint": "biome check . --config-path ./biome.json",
		"format": "biome check --write . --config-path ./biome.json",
		"prepublishOnly": "npm test"
	},
	"keywords": [
		"ai",
		"agents",
		"orchestration",
		"multi-agent",
		"claude-code",
		"codex",
		"aider",
		"worktree",
		"artifacts",
		"claims",
		"compatibility",
		"workflow",
		"subagent"
	],
	"author": "ruah-dev",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ruah-dev/ruah-orch.git"
	},
	"bugs": {
		"url": "https://github.com/ruah-dev/ruah-orch/issues"
	},
	"homepage": "https://github.com/ruah-dev/ruah-orch#readme",
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@ruah-dev/cli": "file:../ruah-cli",
		"@ruah-dev/orch-core": "file:./packages/core"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10"
	}
}

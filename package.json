{
	"name": "@levi-tc/ruah",
	"version": "0.4.1",
	"description": "Multi-agent orchestration. Workspace isolation, DAG scheduling, file locking, subagent spawning, merge coordination. crag-aware.",
	"type": "module",
	"bin": {
		"ruah": "dist/cli.js"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsc && chmod +x dist/cli.js",
		"dev": "tsc --watch",
		"start": "node dist/cli.js",
		"pretest": "tsc -p tsconfig.test.json",
		"test": "node --test dist-test/test/*.test.js",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist dist-test",
		"prepublishOnly": "npm run clean && npm run build && npm test"
	},
	"keywords": [
		"ai",
		"agents",
		"orchestration",
		"multi-agent",
		"claude-code",
		"codex",
		"aider",
		"worktree",
		"workflow",
		"subagent",
		"crag"
	],
	"author": "levi-tc",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/levi-tc/ruah.git"
	},
	"bugs": {
		"url": "https://github.com/levi-tc/ruah/issues"
	},
	"homepage": "https://github.com/levi-tc/ruah#readme",
	"engines": {
		"node": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.2",
		"typescript": "^6.0.2"
	}
}
